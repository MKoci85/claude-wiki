{
  "sections": [
    {
      "title": "Endpoints Principales",
      "articles": [
        {
          "title": "POST /messages",
          "subsections": [
            {
              "title": "Crear una completación",
              "blocks": [
                {
                  "type": "text",
                  "content": "Este es el endpoint principal. Envías mensajes y recibes respuestas del modelo."
                },
                {
                  "type": "code",
                  "language": "bash",
                  "code": "curl https://api.anthropic.com/v1/messages \\\n  -H \"x-api-key: sk-ant-...\" \\\n  -H \"content-type: application/json\" \\\n  -d '{\n    \"model\": \"claude-opus-4-8\",\n    \"max_tokens\": 1024,\n    \"messages\": [\n      {\"role\": \"user\", \"content\": \"Hola\"}\n    ]\n  }'"
                }
              ]
            },
            {
              "title": "Parámetros principales",
              "blocks": [
                {
                  "type": "table",
                  "columns": ["Parámetro", "Tipo", "Requerido", "Descripción"],
                  "rows": [
                    ["model", "string", "Sí", "ID del modelo (ej: claude-opus-4-8)"],
                    ["messages", "array", "Sí", "Historial de mensajes"],
                    ["max_tokens", "integer", "Sí", "Máximo de tokens en la respuesta"],
                    ["system", "string", "No", "Instrucción del sistema"],
                    ["temperature", "float", "No", "Creatividad (0-1, default 1)"],
                    ["top_p", "float", "No", "Diversidad de muestreo"],
                    ["tools", "array", "No", "Funciones disponibles para tool use"]
                  ]
                }
              ]
            },
            {
              "title": "Respuesta",
              "blocks": [
                {
                  "type": "code",
                  "language": "json",
                  "code": "{\n  \"id\": \"msg_123...\",\n  \"type\": \"message\",\n  \"role\": \"assistant\",\n  \"content\": [\n    {\n      \"type\": \"text\",\n      \"text\": \"Hola! ¿Cómo estás?\"\n    }\n  ],\n  \"model\": \"claude-opus-4-8\",\n  \"stop_reason\": \"end_turn\",\n  \"stop_sequence\": null,\n  \"usage\": {\n    \"input_tokens\": 10,\n    \"output_tokens\": 15\n  }\n}"
                }
              ]
            }
          ]
        },
        {
          "title": "GET /models",
          "subsections": [
            {
              "title": "Listar modelos disponibles",
              "blocks": [
                {
                  "type": "text",
                  "content": "Obtiene la lista de modelos que puedes usar con tu API key."
                },
                {
                  "type": "code",
                  "language": "bash",
                  "code": "curl https://api.anthropic.com/v1/models \\\n  -H \"x-api-key: sk-ant-...\""
                }
              ]
            }
          ]
        },
        {
          "title": "POST /messages/count_tokens",
          "subsections": [
            {
              "title": "Contar tokens sin hacer request",
              "blocks": [
                {
                  "type": "text",
                  "content": "Útil para estimar costos o verificar que tu mensaje no exceda límites."
                },
                {
                  "type": "code",
                  "language": "bash",
                  "code": "curl https://api.anthropic.com/v1/messages/count_tokens \\\n  -H \"x-api-key: sk-ant-...\" \\\n  -H \"content-type: application/json\" \\\n  -d '{\n    \"model\": \"claude-opus-4-8\",\n    \"messages\": [{\"role\": \"user\", \"content\": \"¿Cuántos tokens?\"}]\n  }'"
                }
              ]
            }
          ]
        },
        {
          "title": "POST /batches",
          "subsections": [
            {
              "title": "Procesar requests en batch",
              "blocks": [
                {
                  "type": "text",
                  "content": "Subir múltiples requests para procesamiento asincrónico con descuento."
                },
                {
                  "type": "code",
                  "language": "bash",
                  "code": "curl https://api.anthropic.com/v1/batches \\\n  -H \"x-api-key: sk-ant-...\" \\\n  -F \"requests=@requests.jsonl\" \\\n  -X POST"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
